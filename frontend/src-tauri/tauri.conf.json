{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TypeFree",
  "version": "0.2.2",
  "identifier": "com.hill.typefree",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TypeFree",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "../build/icon.png",
      "../build/icon.icns",
      "../build/icon.ico"
    ]
  }
}
