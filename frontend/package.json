{
  "name": "typefree-frontend",
  "private": true,
  "version": "0.1.4",
  "description": "TypeFree is an open-source, local-first Markdown editor with block-based WYSIWYG editing.",
  "author": "Hill-1024 <3520363913@qq.com>",
  "homepage": "https://github.com/Hill-1024/typeFree",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hill-1024/typeFree.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --host 127.0.0.1",
    "dev:desktop": "node ./scripts/electron-dev.mjs",
    "build": "vite build",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "dist": "node ./scripts/electron-dist.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "highlight.js": "latest",
    "katex": "^0.16.45",
    "lucide-react": "latest",
    "marked": "latest",
    "marked-highlight": "latest",
    "mermaid": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "build": {
    "appId": "com.hill.typefree",
    "productName": "TypeFree",
    "icon": "build/icon",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "artifactName": "TypeFree_${version}_macOS_${arch}.${ext}",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
