{
  "name": "typefree",
  "private": true,
  "version": "0.1.3",
  "description": "TypeFree repository workspace entrypoint.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --dir frontend run dev",
    "dev:web": "pnpm --dir frontend run dev:web",
    "dev:desktop": "pnpm --dir frontend run dev:desktop",
    "build": "pnpm --dir frontend run build",
    "build:web": "pnpm --dir frontend run build:web",
    "typecheck": "pnpm --dir frontend run typecheck",
    "dist": "pnpm --dir frontend run dist",
    "dist:desktop": "pnpm --dir frontend run dist",
    "preview": "pnpm --dir frontend run preview"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  }
}
